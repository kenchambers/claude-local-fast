# Qwen3 4B Instruct (2507) — FAST LOCAL profile for the `claude-code` /
# `claude-local-medium` launchers.
# 12k context: with a minimal custom agent the system prompt is only ~3.3k tokens,
# so 12k leaves ample working room (file reads + replies) while staying ~3.6GB
# resident (no swap on 8GB). The speed win comes from the tiny agent prompt
# (~27s prefill vs ~2min), NOT from num_ctx.
# Build: ollama create qwen3-cc -f "$CLAUDE_LOCAL_FAST_DIR/ollama/Modelfile.qwen3-cc"
FROM qwen3:4b-instruct-2507-q4_K_M

PARAMETER num_ctx 12288
PARAMETER num_gpu 99

# Official Qwen3-4B-Instruct-2507 sampling (stable tool-call JSON; repeat_penalty
# forced to 1.0 — Ollama's 1.1 default corrupts code/JSON).
PARAMETER temperature 0.7
PARAMETER top_p 0.8
PARAMETER top_k 20
PARAMETER min_p 0
PARAMETER repeat_penalty 1.0
